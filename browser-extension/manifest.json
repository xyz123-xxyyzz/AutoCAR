{
  "manifest_version": 3,
  "name": "AutoCAR Analiz Edici",
  "version": "2.6",
  "description": "Açık sekmelerdeki araç ilanlarını AutoCAR sistemiyle analiz et.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.sahibinden.com/*",
    "*://*.arabam.com/*",
    "*://*.letgo.com/*",
    "http://localhost:5173/*",
    "http://localhost:5174/*",
    "https://auto-car-gold.vercel.app/*",
    "https://api.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "https://*.vercel.app/*", "https://auto-car-gold.vercel.app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoCAR",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "autocar@example.com",
      "strict_min_version": "109.0"
    }
  }
}
